<% layout("/layouts/boilerplate") %>

<div class="filter-wrapper">

  <button class="scroll-btn" id="scrollLeft">
    <i class="fa-solid fa-chevron-left"></i>
  </button>

  <div id="filters">
    <a href="/listings" class="filter <%= !currCategory ? 'active' : '' %>">
      <i class="fa-solid fa-list"></i>
      <p>All</p>
    </a>
    <a href="/listings?category=Trending" class="filter <%= currCategory === 'Trending' ? 'active' : '' %>">
      <i class="fa-solid fa-fire"></i>
      <p>Trending</p>
    </a>
    <a href="/listings?category=Rooms" class="filter <%= currCategory === 'Rooms' ? 'active' : '' %>">
      <i class="fa-solid fa-bed"></i>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=Iconic Cities" class="filter <%= currCategory === 'Iconic Cities' ? 'active' : '' %>">
      <i class="fa-solid fa-mountain-city"></i>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?category=Mountains" class="filter <%= currCategory === 'Mountains' ? 'active' : '' %>">
      <i class="fa-solid fa-mountain"></i>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=Castles" class="filter <%= currCategory === 'Castles' ? 'active' : '' %>">
      <i class="fa-brands fa-fort-awesome"></i>
      <p>Castles</p>
    </a>
    <a href="/listings?category=Amazing Pools" class="filter <%= currCategory === 'Amazing Pools' ? 'active' : '' %>">
      <i class="fa-solid fa-person-swimming"></i>
      <p>Amazing Pools</p>
    </a>
    <a href="/listings?category=Camping" class="filter <%= currCategory === 'Camping' ? 'active' : '' %>">
      <i class="fa-solid fa-campground"></i>
      <p>Camping</p>
    </a>
    <a href="/listings?category=Farms" class="filter <%= currCategory === 'Farms' ? 'active' : '' %>">
      <i class="fa-solid fa-tractor"></i>
      <p>Farms</p>
    </a>
    <a href="/listings?category=Arctic" class="filter <%= currCategory === 'Arctic' ? 'active' : '' %>">
      <i class="fa-regular fa-snowflake"></i>
      <p>Arctic</p>
    </a>
    <a href="/listings?category=Arctic" class="filter <%= currCategory === 'Arctic' ? 'active' : '' %>">
      <i class="fa-solid fa-ferry"></i>
      <p>Boates</p>
    </a>
    <a href="/listings?category=Camping" class="filter <%= currCategory === 'Camping' ? 'active' : '' %>">
      <i class="fa-solid fa-person-hiking"></i>
      <p>Near Hiking </p>
    </a>
  </div>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total before taxes</label>
    </div>
  </div>

  <button class="scroll-btn" id="scrollRight">
    <i class="fa-solid fa-chevron-right"></i>
  </button>

</div>
<% if (currQuery) { %>
  <p class="text-muted mt-2">
    <%= alllisting.length %> result<%= alllisting.length !== 1 ? 's' : '' %> 
    for "<b><%= currQuery %></b>"
    <a href="/listings" class="ms-2 text-success" style="font-size:0.9rem;">Clear</a>
  </p>
<% } %>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-4">
  <% if (alllisting.length === 0) { %>
    <div class="col-12 no-results">
      <i class="fa-solid fa-triangle-exclamation"></i>
      No listings found for "<%= currCategory %>" category.
      <br><a href="/listings">View all listings</a>
    </div>
  <% } else { %>
    <% for (let listing of alllisting) { %>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card">
          <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;"/>
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>
              &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "1200" %> / night
              <i class="tax-info"> &nbsp; &nbsp;+18% GST </i>
            </p>
          </div>
        </div>
      </a>
    <% } %>
  <% } %>
</div>
<script>
  let taxSwitch = document.getElementById("switchCheckDefault")
  taxSwitch.addEventListener("click",() => {
    let taxinfo = document.getElementsByClassName("tax-info");
    for(info of taxinfo){
      if(info.style.display != "inline"){
        info.style.display = "inline"; 
      }else{
        info.style.display = "none";
      }
    }
  })
</script>
<script>
  const filters  = document.getElementById("filters");
  const leftBtn  = document.getElementById("scrollLeft");
  const rightBtn = document.getElementById("scrollRight");

  leftBtn.style.display = "none";

  leftBtn.addEventListener("click",  () => filters.scrollBy({ left: -200, behavior: "smooth" }));
  rightBtn.addEventListener("click", () => filters.scrollBy({ left:  200, behavior: "smooth" }));

  filters.addEventListener("scroll", () => {
    leftBtn.style.display  = filters.scrollLeft > 0 ? "flex" : "none";
    rightBtn.style.display = filters.scrollLeft + filters.clientWidth < filters.scrollWidth - 1
      ? "flex" : "none";
  });
</script>
